{
  "name": "@vaultledger/cli",
  "version": "0.4.0",
  "type": "module",
  "description": "VaultLedger CLI — set up and govern an AI agent's Obsidian-vault memory (ledger setup/approve/undo)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "bin": { "ledger": "./bin/ledger.mjs" },
  "files": ["dist", "bin/ledger.mjs"],
  "scripts": { "build": "tsc -b", "test": "vitest run" },
  "license": "MIT",
  "author": "Kristopher Dunham",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ktopper/VaultLedger.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Ktopper/VaultLedger#readme",
  "bugs": "https://github.com/Ktopper/VaultLedger/issues",
  "keywords": ["obsidian", "mcp", "agent-memory", "provenance", "ai-memory"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.1.0",
    "diff": "^8.0.3",
    "yaml": "^2.5.0",
    "@vaultledger/core": "workspace:*",
    "@vaultledger/server": "workspace:*",
    "@vaultledger/mcp-server": "workspace:*"
  },
  "devDependencies": {
    "@vaultledger/obsidian-plugin": "workspace:*"
  }
}
