{
  "name": "@vault-ledger/core",
  "version": "0.4.4",
  "type": "module",
  "description": "VaultLedger broker core — governed, provenance-tracked memory for AI agents over an Obsidian vault",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./config": { "types": "./dist/config.d.ts", "default": "./dist/config.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "prepack": "node ../../scripts/prepack-check.mjs"
  },
  "license": "MIT",
  "author": "Kristopher Dunham",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ktopper/VaultLedger.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Ktopper/VaultLedger#readme",
  "bugs": "https://github.com/Ktopper/VaultLedger/issues",
  "keywords": ["obsidian", "mcp", "agent-memory", "provenance", "ai-memory"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "zod": "^3.23.0",
    "better-sqlite3": "^11.3.0",
    "simple-git": "^3.27.0",
    "picomatch": "^4.0.0",
    "gray-matter": "^4.0.3",
    "diff": "^8.0.3",
    "yaml": "^2.5.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/picomatch": "^3.0.0",
    "@types/proper-lockfile": "^4.1.4"
  }
}
