{
  "name": "vaultledger",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "bootstrap": "pnpm install && pnpm build && pnpm -C packages/obsidian-plugin build"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.2.7",
    "eslint": "^9.10.0",
    "typescript-eslint": "^8.8.0",
    "@types/node": "^22.5.0",
    "@vault-ledger/cli": "workspace:*",
    "@vault-ledger/mcp-server": "workspace:*"
  }
}
